{
  "folders": [
    {
      "path": "python",
      "name": "TurboQuant Python"
    },
    {
      "path": "core/include",
      "name": "Core Headers (reference)"
    }
  ],
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": ["benchmarks", "tests"],
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.linting.mypyEnabled": true,
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": ["--line-length", "100"],
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.rulers": [100],
    "editor.minimap.enabled": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "terminal.integrated.gpuAcceleration": "on",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
      "**/__pycache__": true,
      "**/*.pyc": true,
      "**/.mypy_cache": true,
      "**/.pytest_cache": true,
      "**/*.egg-info": true
    },
    "files.watcherExclude": {
      "**/.venv/**": true,
      "**/__pycache__/**": true
    },
    "search.exclude": {
      "**/.venv": true,
      "**/__pycache__": true
    },
    "jupyter.widgetScriptSources": ["jsdelivr.com", "unpkg.com"],
    "[python]": {
      "editor.defaultFormatter": "ms-python.black-formatter",
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
      }
    }
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "ms-python.black-formatter",
      "ms-python.isort",
      "ms-toolsai.jupyter",
      "ms-toolsai.vscode-jupyter-cell-tags",
      "charliermarsh.ruff"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Setup Virtual Environment",
        "type": "shell",
        "command": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
        "group": "build"
      },
      {
        "label": "Run Tests",
        "type": "shell",
        "command": "source .venv/bin/activate && pytest -v --tb=short",
        "group": { "kind": "test", "isDefault": true }
      },
      {
        "label": "Run Benchmarks",
        "type": "shell",
        "command": "source .venv/bin/activate && python benchmarks/speed_test.py"
      },
      {
        "label": "Build C++ Extension",
        "type": "shell",
        "command": "source .venv/bin/activate && pip install -e .",
        "group": "build"
      },
      {
        "label": "Type Check (mypy)",
        "type": "shell",
        "command": "source .venv/bin/activate && mypy turboquant_py/ --ignore-missing-imports"
      },
      {
        "label": "Lint (ruff)",
        "type": "shell",
        "command": "source .venv/bin/activate && ruff check ."
      }
    ]
  }
}
